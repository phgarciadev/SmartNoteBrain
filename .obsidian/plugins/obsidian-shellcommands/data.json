    {
      "id": "notebooklm_generate",
      "platform_specific_commands": {
        "default": "python3 PyScripts/send_to_notebooklm.py {{file_path:absolute}}"
      },
      "shells": {},
      "alias": "NotebookLM Generate",
      "icon": null,
      "confirm_execution": false,
      "ignore_error_codes": [],
      "input_contents": {
        "stdin": null
      },
      "output_handlers": {
        "stdout": {
          "handler": "notification",
          "convert_ansi_code": true
        },
        "stderr": {
          "handler": "notification",
          "convert_ansi_code": true
        }
      },
      "output_wrappers": {
        "stdout": null,
        "stderr": null
      },
      "output_channel_order": "stdout-first",
      "output_handling_mode": "buffered",
      "execution_notification_mode": "enabled",
